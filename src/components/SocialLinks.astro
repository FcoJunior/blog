---
import BrandIcon from './BrandIcon.astro';

interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;

const links = [
  { label: 'GitHub', href: 'https://github.com/fcojunior' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/fcojunr/' },
  { label: 'Instagram', href: 'https://www.instagram.com/devjunr' }
] as const;
---

<ul class={compact ? 'flex flex-wrap gap-3' : 'flex flex-wrap items-center gap-4'}>
  {links.map((link) => (
    <li>
      <a
        href={link.href}
        target="_blank"
        rel="noreferrer"
        class="inline-flex items-center gap-2 rounded-full border border-grey-150 px-3 py-2 text-sm font-medium text-grey-500 transition hover:-translate-y-0.5 hover:border-grey-300 hover:bg-grey-50 hover:text-grey-800 dark:border-grey-600 dark:text-grey-300 dark:hover:border-grey-500 dark:hover:bg-grey-800 dark:hover:text-grey-50"
        aria-label={link.label}
      >
        <BrandIcon name={link.label} class="h-4 w-4" />
        <span>{link.label}</span>
      </a>
    </li>
  ))}
</ul>

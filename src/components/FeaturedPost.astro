---
import { getCategoryMetadata } from '@config/categories';
import type { Lang } from '@i18n/index';
import { getTranslations } from '@i18n/index';
import type { Post } from '@utils/posts';
import { getPostCover, getPostUrl, getReadingTime } from '@utils/posts';
import { getCategoryTheme } from '@utils/categoryTheme';
import HeroIcon from './HeroIcon.astro';

interface Props {
  post?: Post;
  lang: Lang;
}

const { post, lang } = Astro.props;
const t = getTranslations(lang);
const category = post ? getCategoryMetadata(lang, post.data.category) : undefined;
const theme = category ? getCategoryTheme(category.color) : undefined;
const categoryHref = category?.href ?? '#';
const categoryIcon = category?.icon ?? 'BookOpenIcon';
const categoryTitle = category?.title ?? '';
---

{
  post && (
    <section class="page-shell py-12">
      <div class="mb-6 flex items-center justify-between gap-4">
        <h2 class="text-2xl font-bold text-grey-800 dark:text-grey-50">{t.home.featuredTitle}</h2>
      </div>
      <article class="grid overflow-hidden rounded-2xl border border-grey-150 bg-grey-25 shadow-sm dark:border-grey-600 dark:bg-grey-900 lg:grid-cols-[1.15fr_0.85fr]">
        <a href={getPostUrl(post)} class="block bg-grey-100 dark:bg-grey-800">
          <img
            src={getPostCover(post)}
            alt={`${t.posts.coverAlt} ${post.data.title}`}
            class="h-full min-h-72 w-full object-cover"
            loading="lazy"
          />
        </a>
        <div class="flex flex-col justify-center p-6 sm:p-8 lg:p-10">
          <a href={categoryHref} class:list={['inline-flex w-fit items-center gap-1.5 rounded-full px-2.5 py-1 text-xs font-semibold', theme?.chip]}>
            <HeroIcon name={categoryIcon} class="h-3.5 w-3.5" />
            {categoryTitle}
          </a>
          <a href={getPostUrl(post)} class="mt-3 text-2xl font-bold leading-tight text-grey-800 hover:text-primary-500 dark:text-grey-50 sm:text-3xl">
            {post.data.title}
          </a>
          <p class="mt-4 leading-7 text-grey-500 dark:text-grey-300">{post.data.description}</p>
          <div class="mt-6 flex items-center gap-2 text-sm text-grey-500 dark:text-grey-300">
            <HeroIcon name="ClockIcon" class="h-4 w-4" />
            <span>{getReadingTime(post, lang)}</span>
          </div>
          <a href={getPostUrl(post)} class="mt-8 inline-flex w-fit items-center gap-2 rounded-lg bg-grey-800 px-4 py-2.5 font-semibold text-grey-50 transition hover:-translate-y-0.5 hover:bg-grey-700 dark:bg-grey-50 dark:text-grey-900 dark:hover:bg-grey-100">
            {t.home.readPost}
            <HeroIcon name="ArrowRightIcon" class="h-4 w-4" />
          </a>
        </div>
      </article>
    </section>
  )
}

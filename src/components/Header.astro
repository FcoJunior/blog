---
import SearchCommand from './SearchCommand.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import type { Lang } from '@i18n/index';
import { getTranslations, homeUrl } from '@i18n/index';

interface Props {
  lang?: Lang;
  languageUrls?: Partial<Record<Lang, string>>;
}

const { lang = 'pt', languageUrls = {} } = Astro.props;
const t = getTranslations(lang);
---

<div class="page-shell fixed w-full bg-grey-900 shadow-lg z-20">
  <nav class="flex gap-3 justify-between pt-8 pb-4 sm:gap-6">
    <div>
      <a href={homeUrl(lang)} aria-label="Dev Junior">
        <img class="w-12 lg:w-16" src="/images/logo-menu.png" alt="Dev Junior" />
      </a>
    </div>
    <ul class="flex items-center grow justify-end gap-8 font-semibold text-grey-200">
      <li class="hover:text-grey-50">
        <a href={homeUrl(lang)}>{t.nav.home}</a>
      </li>
    </ul>
    <div class="flex items-center gap-3">
      <LanguageSwitcher lang={lang} urls={languageUrls} />
      <SearchCommand lang={lang} />
    </div>
  </nav>
</div>

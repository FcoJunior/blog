---
import SearchCommand from './SearchCommand.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import ThemeToggle from './ThemeToggle.astro';
import type { Lang } from '@i18n/index';
import { homeUrl } from '@i18n/index';

interface Props {
  lang?: Lang;
  languageUrls?: Partial<Record<Lang, string>>;
}

const { lang = 'pt', languageUrls = {} } = Astro.props;
---

<div class="page-shell fixed z-20 w-full border-b border-grey-150 bg-grey-75/95 backdrop-blur transition-colors dark:border-grey-600 dark:bg-grey-900/95">
  <nav class="flex items-center justify-between gap-3 py-3 sm:gap-6">
    <div>
      <a href={homeUrl(lang)} aria-label="Dev Junior">
        <img class="h-10 w-auto dark:hidden lg:h-12" src="/images/Logo-Light.png" alt="Dev Junior" />
        <img class="hidden h-10 w-auto dark:block lg:h-12" src="/images/Logo-Dark.png" alt="Dev Junior" />
      </a>
    </div>
    <div class="flex items-center gap-3">
      <LanguageSwitcher lang={lang} urls={languageUrls} />
      <ThemeToggle lang={lang} />
      <SearchCommand lang={lang} />
    </div>
  </nav>
</div>

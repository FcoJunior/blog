---
import SearchCommand from './SearchCommand.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import ThemeToggle from './ThemeToggle.astro';
import type { Lang } from '@i18n/index';
import { homeUrl } from '@i18n/index';

interface Props {
  lang?: Lang;
  languageUrls?: Partial<Record<Lang, string>>;
}

const { lang = 'pt', languageUrls = {} } = Astro.props;
---

<div class="page-shell fixed z-20 w-full bg-grey-75 shadow-lg transition-colors dark:bg-grey-900">
  <nav class="flex gap-3 justify-between pt-8 pb-4 sm:gap-6">
    <div>
      <a href={homeUrl(lang)} aria-label="Dev Junior">
        <img class="w-12 lg:w-16" src="/images/logo-menu.png" alt="Dev Junior" />
      </a>
    </div>
    <div class="flex items-center gap-3">
      <LanguageSwitcher lang={lang} urls={languageUrls} />
      <ThemeToggle lang={lang} />
      <SearchCommand lang={lang} />
    </div>
  </nav>
</div>

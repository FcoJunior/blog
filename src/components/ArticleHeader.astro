---
import type { Lang } from '@i18n/index';
import type { Post } from '@utils/posts';
import { getPostCover } from '@utils/posts';
import ArticleMeta from './ArticleMeta.astro';

interface Props {
  post: Post;
  lang: Lang;
}

const { post, lang } = Astro.props;
---

<header class="page-shell pb-12 pt-10 sm:pb-16 sm:pt-14 lg:pb-20 lg:pt-16">
  <div class="mx-auto max-w-4xl text-center">
    <ArticleMeta post={post} lang={lang} />
    <h1 class="mt-6 text-4xl font-bold leading-tight tracking-normal text-grey-800 dark:text-grey-50 sm:text-5xl lg:text-6xl" data-pagefind-meta="title">
      {post.data.title}
    </h1>
    {
      post.data.description && (
        <p class="mx-auto mt-6 max-w-3xl text-lg leading-8 text-grey-500 dark:text-grey-300 sm:text-xl sm:leading-9">
          {post.data.description}
        </p>
      )
    }
  </div>
  <div class="mx-auto mt-12 max-w-6xl sm:mt-14 lg:mt-16">
    <img
      class="aspect-[16/9] w-full rounded-2xl border border-grey-150 bg-grey-100 object-cover shadow-sm dark:border-grey-600 dark:bg-grey-800"
      src={getPostCover(post)}
      alt={post.data.title}
    />
  </div>
</header>

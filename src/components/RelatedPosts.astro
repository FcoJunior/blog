---
import { getTranslations, type Lang } from '@i18n/index';
import type { Post } from '@utils/posts';
import { getCategoryUrl, getPostCover, getPostSlug, getPostUrl, getReadingTime } from '@utils/posts';

interface Props {
  posts: Post[];
  currentPost: Post;
  lang: Lang;
}

const { posts, currentPost, lang } = Astro.props;
const t = getTranslations(lang);
const currentSlug = getPostSlug(currentPost);
const relatedPosts = posts
  .filter((post) => getPostSlug(post) !== currentSlug)
  .slice(0, 4);
---

{
  relatedPosts.length > 0 && (
    <section class="page-shell pb-20 pt-4 sm:pb-24">
      <div class="mx-auto max-w-6xl">
        <h2 class="text-2xl font-bold text-grey-800 dark:text-grey-50">{t.posts.relatedTitle}</h2>
        <div class="mt-8 grid gap-6 md:grid-cols-2 xl:grid-cols-4">
          {relatedPosts.map((post) => (
            <article class="flex min-h-full flex-col overflow-hidden rounded-xl border border-grey-150 bg-grey-25 shadow-sm transition hover:-translate-y-1 hover:border-grey-300 hover:shadow-md dark:border-grey-600 dark:bg-grey-900 dark:hover:border-grey-500">
              <a href={getPostUrl(post)} class="block bg-grey-100 dark:bg-grey-800">
                <img
                  src={getPostCover(post)}
                  alt={`${t.posts.coverAlt} ${post.data.title}`}
                  class="aspect-[16/9] w-full object-cover"
                  loading="lazy"
                />
              </a>
              <div class="flex grow flex-col p-5">
                <a href={getCategoryUrl(lang, post.data.category)} class="text-xs font-semibold text-primary-500 hover:text-primary-400">
                  {post.data.category}
                </a>
                <a href={getPostUrl(post)} class="mt-3 text-lg font-bold leading-snug text-grey-800 hover:text-primary-500 dark:text-grey-50">
                  {post.data.title}
                </a>
                <p class="mt-5 text-sm text-grey-500 dark:text-grey-300">{getReadingTime(post, lang)}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )
}

---
import { getTranslations, type Lang } from '@i18n/index';
import AuthorCard from './AuthorCard.astro';

interface Props {
  lang: Lang;
  constrained?: boolean;
}

const { lang, constrained = false } = Astro.props;
const t = getTranslations(lang);
const innerClass = constrained ? 'mx-auto max-w-6xl' : '';
---

<section id={t.home.authorId} class="page-shell scroll-mt-28 py-16">
  <div class={innerClass}>
    <AuthorCard lang={lang} />
  </div>
</section>

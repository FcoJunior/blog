---
import HeroIcon from './HeroIcon.astro';

interface Props {
  name: string;
  count: string;
  icon: string;
  href: string;
}

const { name, count, icon, href } = Astro.props;
---

<a href={href} class="flex items-center gap-4 rounded-xl border border-grey-150 bg-grey-25 p-5 transition hover:-translate-y-1 hover:border-grey-300 hover:shadow-sm dark:border-grey-600 dark:bg-grey-900 dark:hover:border-grey-500">
  <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg border border-grey-150 bg-grey-50 text-primary-500 dark:border-grey-600 dark:bg-grey-800">
    <HeroIcon name={icon} class="h-5 w-5" />
  </div>
  <div class="min-w-0">
    <h3 class="truncate font-semibold text-grey-800 dark:text-grey-50">{name}</h3>
    <p class="mt-1 text-sm text-grey-500 dark:text-grey-300">{count}</p>
  </div>
</a>

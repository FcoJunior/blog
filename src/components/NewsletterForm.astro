---
import type { Lang } from '@i18n/index';
import { getTranslations } from '@i18n/index';

interface Props {
  compact?: boolean;
  lang?: Lang;
}

const { compact = false, lang = 'pt' } = Astro.props;
const t = getTranslations(lang);
const action = import.meta.env.PUBLIC_NEWSLETTER_ACTION;
const formClass = compact ? 'flex flex-col gap-2' : 'flex flex-col md:flex-row gap-4';
const inputClass = compact
  ? 'bg-grey-25 border border-grey-150 rounded-2xl py-2 px-4 focus:outline-none focus:ring-2 focus:ring-primary-500 placeholder:text-grey-300 w-full dark:bg-grey-600 dark:border-grey-600'
  : 'flex-1 bg-grey-25 border border-grey-150 rounded-2xl py-2 px-4 focus:outline-none focus:ring-2 focus:ring-primary-500 placeholder:text-grey-300 w-full lg:w-1/3 dark:bg-grey-900 dark:border-grey-600';
---

<form class={formClass} method="post" action={action}>
  <input
    type="email"
    autocomplete="off"
    name="email"
    placeholder={t.newsletter.placeholder}
    class={inputClass}
  />
  <button type="submit" class="bg-primary-600 px-4 py-2 rounded-2xl text-grey-50 hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500">
    {t.newsletter.button}
  </button>
</form>

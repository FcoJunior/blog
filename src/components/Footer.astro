---
import NewsletterForm from './NewsletterForm.astro';
import type { Lang } from '@i18n/index';
import { getTranslations } from '@i18n/index';

interface Props {
  lang?: Lang;
}

const { lang = 'pt' } = Astro.props;
const t = getTranslations(lang);
---

<aside class="page-shell flex flex-col items-end gap-8 bg-grey-75 py-8 transition-colors dark:bg-grey-700 md:flex-row">
  <div class="flex-1">
    <h3 class="text-2xl font-semibold pb-6">{t.newsletter.title}</h3>
    <p class="text-grey-500 dark:text-grey-300">
      {t.newsletter.description}
    </p>
  </div>
  <div class="flex-1 w-full">
    <NewsletterForm lang={lang} />
  </div>
</aside>
<footer class="page-shell flex items-center justify-between bg-grey-75 py-8 text-grey-500 transition-colors dark:bg-grey-900 dark:text-grey-200">
  <div>
    <span>&copy; Dev Junior {new Date().getFullYear()}</span>
  </div>
  <ul class="flex gap-4">
    <li>
      <a href="https://www.instagram.com/devjunr" target="_blank" rel="noreferrer" class="fill-grey-300 hover:fill-grey-100" aria-label="Instagram">
        <img src="/images/instagram.png" alt="" class="h-8 w-8" />
      </a>
    </li>
    <li>
      <a href="https://www.linkedin.com/in/fcojunr/" target="_blank" rel="noreferrer" class="fill-grey-300 hover:fill-grey-100" aria-label="LinkedIn">
        <img src="/images/linkedin.png" alt="" class="h-8 w-8" />
      </a>
    </li>
  </ul>
</footer>

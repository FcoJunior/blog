---
import { listCategories } from '@config/categories';
import { articlesUrl, getTranslations, homeUrl, type Lang } from '@i18n/index';
import BrandIcon from './BrandIcon.astro';

interface Props {
  lang?: Lang;
}

const { lang = 'pt' } = Astro.props;
const t = getTranslations(lang);
const categoryAnchor = `${homeUrl(lang)}#${t.home.categoriesId}`;
const aboutAnchor = `${homeUrl(lang)}#${t.home.authorId}`;
const categories = listCategories(lang);

const socialLinks = [
  { label: 'GitHub', href: 'https://github.com/fcojunior' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/fcojunr/' },
  { label: 'Instagram', href: 'https://www.instagram.com/devjunr' }
] as const;
---

<footer class="page-shell border-t border-grey-150 bg-grey-75 py-12 text-grey-500 transition-colors dark:border-grey-600 dark:bg-grey-900 dark:text-grey-300">
  <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
    <div>
      <h2 class="text-lg font-bold text-grey-800 dark:text-grey-50">Dev Junior</h2>
      <p class="mt-3 max-w-xs leading-7">
        {t.site.description}
      </p>
    </div>
    <nav aria-label={t.nav.articles}>
      <h3 class="font-semibold text-grey-800 dark:text-grey-50">{t.nav.articles}</h3>
      <ul class="mt-4 space-y-3">
        <li><a href={articlesUrl(lang)} class="hover:text-primary-500">{t.nav.articles}</a></li>
        <li><a href={categoryAnchor} class="hover:text-primary-500">{t.home.categoriesTitle}</a></li>
        <li><a href={aboutAnchor} class="hover:text-primary-500">{t.home.aboutMe}</a></li>
      </ul>
    </nav>
    <nav aria-label={t.home.categoriesTitle}>
      <h3 class="font-semibold text-grey-800 dark:text-grey-50">{t.home.categoriesTitle}</h3>
      <ul class="mt-4 space-y-3">
        {categories.slice(0, 4).map((category) => (
          <li><a href={category.href} class="hover:text-primary-500">{category.title}</a></li>
        ))}
      </ul>
    </nav>
    <nav aria-label={t.home.socialLabel}>
      <h3 class="font-semibold text-grey-800 dark:text-grey-50">{t.home.socialLabel}</h3>
      <ul class="mt-4 space-y-3">
        {socialLinks.map((link) => (
          <li>
            <a href={link.href} target="_blank" rel="noreferrer" class="inline-flex items-center gap-2 hover:text-primary-500">
              <BrandIcon name={link.label} class="h-4 w-4" />
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
  <div class="mt-10 border-t border-grey-150 pt-6 text-sm dark:border-grey-600">
    <span>&copy; Dev Junior {new Date().getFullYear()}</span>
  </div>
</footer>

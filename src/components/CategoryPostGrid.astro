---
import { articlesUrl, type Lang } from '@i18n/index';
import type { Post } from '@utils/posts';
import HeroIcon from './HeroIcon.astro';
import PostCard from './PostCard.astro';

interface Props {
  posts: Post[];
  lang: Lang;
}

const { posts, lang } = Astro.props;
const title = lang === 'en' ? 'Latest articles' : 'Últimos artigos';
const emptyTitle = lang === 'en' ? 'No articles found.' : 'Nenhum artigo encontrado.';
const emptyDescription = lang === 'en'
  ? 'There are no posts in this category yet.'
  : 'Ainda não existem publicações nesta categoria.';
const buttonLabel = lang === 'en' ? 'View all articles' : 'Ver todos os artigos';
---

<section class="page-shell py-14">
  <h2 class="mb-8 text-2xl font-bold text-grey-800 dark:text-grey-50">{title}</h2>
  {
    posts.length > 0 ? (
      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {posts.map((post) => <PostCard post={post} lang={lang} />)}
      </div>
    ) : (
      <div class="mx-auto flex max-w-md flex-col items-center py-16 text-center">
        <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-2xl border border-grey-150 bg-grey-25 text-primary-500 dark:border-grey-600 dark:bg-grey-800 dark:text-primary-300">
          <HeroIcon name="BookOpenIcon" class="h-7 w-7" />
        </div>
        <h3 class="text-xl font-bold text-grey-800 dark:text-grey-50">{emptyTitle}</h3>
        <p class="mt-3 leading-7 text-grey-500 dark:text-grey-300">{emptyDescription}</p>
        <a href={articlesUrl(lang)} class="mt-7 inline-flex items-center gap-2 rounded-lg border border-grey-150 bg-grey-25 px-5 py-3 font-semibold text-grey-700 transition hover:-translate-y-0.5 hover:border-grey-300 hover:bg-grey-50 dark:border-grey-600 dark:bg-grey-900 dark:text-grey-100 dark:hover:border-grey-500 dark:hover:bg-grey-800">
          {buttonLabel}
          <HeroIcon name="ArrowRightIcon" class="h-4 w-4" />
        </a>
      </div>
    )
  }
</section>

---
import type { CategoryMetadata } from '@config/categories';
import { formatArticleCount } from '@utils/posts';
import { getCategoryTheme } from '@utils/categoryTheme';
import type { Lang } from '@i18n/index';
import HeroIcon from './HeroIcon.astro';

interface Props {
  category: CategoryMetadata;
  count: number;
  lang: Lang;
}

const { category, count, lang } = Astro.props;
const articleCount = formatArticleCount(count, lang);
const publishedLabel = lang === 'en'
  ? `${articleCount} published`
  : `${articleCount} publicado${count === 1 ? '' : 's'}`;
const theme = getCategoryTheme(category.color);
---

<header class="mx-auto flex max-w-3xl flex-col items-center py-16 text-center md:py-20">
  <div class:list={['mb-6 flex h-16 w-16 items-center justify-center rounded-2xl border shadow-sm', theme.icon]}>
    <HeroIcon name={category.icon} class="h-8 w-8" />
  </div>
  <h1 class="text-4xl font-bold tracking-normal text-grey-800 dark:text-grey-50 md:text-5xl">{category.title}</h1>
  <p class="mt-5 max-w-2xl text-lg leading-8 text-grey-500 dark:text-grey-300">{category.description}</p>
  <p class="mt-6 font-mono text-sm text-primary-500 dark:text-primary-300">{publishedLabel}</p>
</header>

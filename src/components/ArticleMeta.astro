---
import { getCategoryMetadata } from '@config/categories';
import type { Lang } from '@i18n/index';
import type { Post } from '@utils/posts';
import { formatDate, getReadingTime } from '@utils/posts';

interface Props {
  post: Post;
  lang: Lang;
}

const { post, lang } = Astro.props;
const category = getCategoryMetadata(lang, post.data.category);
---

<div class="flex flex-wrap items-center justify-center gap-x-3 gap-y-2 text-sm font-medium text-grey-500 dark:text-grey-300">
  <a href={category.href} class="transition hover:text-primary-500 dark:hover:text-primary-300">
    {category.title}
  </a>
  <span class="text-grey-300 dark:text-grey-500">•</span>
  <span>{getReadingTime(post, lang)}</span>
  <span class="text-grey-300 dark:text-grey-500">•</span>
  <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate, lang)}</time>
</div>

---
import { DEFAULT_COVER } from '@utils/posts';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
  type?: 'website' | 'article';
  pubDate?: Date;
  updatedDate?: Date;
}

const {
  title = 'Dev Junior',
  description = 'Reflexoes e aprendizados sobre desenvolvimento, arquitetura, .NET e carreira em tecnologia.',
  image = DEFAULT_COVER,
  canonical = Astro.url.pathname,
  type = 'website',
  pubDate,
  updatedDate
} = Astro.props;

const site = Astro.site ?? new URL('https://example.com');
const pageTitle = title === 'Dev Junior' ? title : `${title} | Dev Junior`;
const canonicalUrl = new URL(canonical, site).toString();
const imageUrl = new URL(image, site).toString();
---

<title>{pageTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />

<meta property="og:type" content={type} />
<meta property="og:site_name" content="Dev Junior" />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={imageUrl} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />

{pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
{updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}

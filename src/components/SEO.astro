---
import { DEFAULT_COVER } from '@utils/posts';
import type { Lang } from '@i18n/index';
import { languageConfig } from '@i18n/index';

interface Alternate {
  hrefLang: string;
  href: string;
}

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
  type?: 'website' | 'article';
  pubDate?: Date;
  updatedDate?: Date;
  lang?: Lang;
  alternates?: Alternate[];
}

const {
  title = 'Dev Junior',
  description = 'Reflexoes e aprendizados sobre desenvolvimento, arquitetura, .NET e carreira em tecnologia.',
  image = DEFAULT_COVER,
  canonical = Astro.url.pathname,
  type = 'website',
  pubDate,
  updatedDate,
  lang = 'pt',
  alternates = []
} = Astro.props;

const site = Astro.site ?? new URL('https://example.com');
const pageTitle = title === 'Dev Junior' ? title : `${title} | Dev Junior`;
const canonicalUrl = new URL(canonical, site).toString();
const imageUrl = new URL(image, site).toString();
const ogLocale = languageConfig[lang].ogLocale;
---

<title>{pageTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />

<meta property="og:type" content={type} />
<meta property="og:site_name" content="Dev Junior" />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={imageUrl} />
<meta property="og:locale" content={ogLocale} />

{alternates.map((alternate) => (
  <link rel="alternate" hreflang={alternate.hrefLang} href={new URL(alternate.href, site).toString()} />
))}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />

{pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
{updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}

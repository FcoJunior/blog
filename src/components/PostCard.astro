---
import type { Post } from '@utils/posts';
import { formatDate, getCategoryUrl, getPostCover, getPostUrl, getTagUrl } from '@utils/posts';
import type { Lang } from '@i18n/index';
import { getTranslations } from '@i18n/index';

interface Props {
  post: Post;
  lang?: Lang;
}

const { post, lang = post.data.lang } = Astro.props;
const t = getTranslations(lang);
---

<article class="w-full md:w-1/2 lg:w-1/3 xl:w-1/4">
  <div class="border border-grey-600 rounded-2xl m-3 h-[calc(100%-1.5rem)] flex flex-col overflow-hidden">
    <a href={getPostUrl(post)} class="block bg-grey-700">
      <img
        class="rounded-t-2xl w-full aspect-[1882/930] object-cover"
        src={getPostCover(post)}
        alt={`${t.posts.coverAlt} ${post.data.title}`}
        loading="lazy"
      />
    </a>
    <div class="p-4 text-grey-50 flex flex-col gap-4 grow">
      <div class="flex flex-col gap-2">
        <div class="text-primary-400 font-mono flex flex-wrap gap-x-2 gap-y-1">
          {post.data.tags.map((tag) => (
            <a href={getTagUrl(lang, tag)} class="hover:text-primary-300"># {tag}</a>
          ))}
        </div>
        <a class="font-bold text-lg hover:text-primary-500" href={getPostUrl(post)}>{post.data.title}</a>
      </div>
      <p class="text-grey-300 text-justify grow">{post.data.description}</p>
      <div class="flex flex-wrap gap-2 text-grey-300 font-mono text-sm">
        <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate, lang)}</time>
        <span aria-hidden="true">-</span>
        <a href={getCategoryUrl(lang, post.data.category)} class="hover:text-primary-400">{post.data.category}</a>
      </div>
    </div>
  </div>
</article>

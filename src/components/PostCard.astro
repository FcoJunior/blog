---
import type { Post } from '@utils/posts';
import { formatDate, getCategoryUrl, getPostCover, getPostUrl } from '@utils/posts';
import type { Lang } from '@i18n/index';
import { getTranslations } from '@i18n/index';

interface Props {
  post: Post;
  lang?: Lang;
}

const { post, lang = post.data.lang } = Astro.props;
const t = getTranslations(lang);
---

<article class="w-full md:w-1/2 lg:w-1/3 xl:w-1/4">
  <div class="m-3 flex h-[calc(100%-1.5rem)] flex-col overflow-hidden rounded-2xl border border-grey-150 bg-grey-25 transition-colors dark:border-grey-600 dark:bg-grey-900">
    <a href={getPostUrl(post)} class="block bg-grey-75 dark:bg-grey-700">
      <img
        class="rounded-t-2xl w-full aspect-[1882/930] object-cover"
        src={getPostCover(post)}
        alt={`${t.posts.coverAlt} ${post.data.title}`}
        loading="lazy"
      />
    </a>
      <div class="flex grow flex-col gap-4 p-4 text-grey-800 dark:text-grey-50">
      <div class="flex flex-col gap-2">
        <a href={getCategoryUrl(lang, post.data.category)} class="font-mono text-primary-400 hover:text-primary-300">{post.data.category}</a>
        <a class="font-bold text-lg hover:text-primary-500" href={getPostUrl(post)}>{post.data.title}</a>
      </div>
      <p class="grow text-justify text-grey-500 dark:text-grey-300">{post.data.description}</p>
      <div class="flex flex-wrap gap-2 font-mono text-sm text-grey-500 dark:text-grey-300">
        <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate, lang)}</time>
        <span aria-hidden="true">-</span>
        <a href={getCategoryUrl(lang, post.data.category)} class="hover:text-primary-400">{post.data.category}</a>
      </div>
    </div>
  </div>
</article>

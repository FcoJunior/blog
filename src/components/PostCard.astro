---
import { getCategoryMetadata } from '@config/categories';
import type { Post } from '@utils/posts';
import { formatDate, getPostCover, getPostUrl, getReadingTime } from '@utils/posts';
import { getCategoryTheme } from '@utils/categoryTheme';
import type { Lang } from '@i18n/index';
import { getTranslations } from '@i18n/index';
import HeroIcon from './HeroIcon.astro';

interface Props {
  post: Post;
  lang?: Lang;
}

const { post, lang = post.data.lang } = Astro.props;
const t = getTranslations(lang);
const category = getCategoryMetadata(lang, post.data.category);
const theme = getCategoryTheme(category.color);
---

<article class="min-w-0">
  <a href={getPostUrl(post)} class="group flex h-full flex-col overflow-hidden rounded-2xl border border-grey-150 bg-grey-25 shadow-sm transition duration-200 hover:-translate-y-1 hover:border-grey-300 hover:shadow-md focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-400 dark:border-grey-600 dark:bg-grey-900 dark:hover:border-grey-500">
    <span class="block overflow-hidden bg-grey-75 dark:bg-grey-700">
      <img
        class="aspect-[16/9] w-full object-cover transition duration-300 group-hover:scale-[1.02]"
        src={getPostCover(post)}
        alt={`${t.posts.coverAlt} ${post.data.title}`}
        loading="lazy"
      />
    </span>
    <span class="flex grow flex-col p-5 text-grey-800 dark:text-grey-50">
      <span class:list={['mb-4 inline-flex w-fit items-center gap-1.5 rounded-full px-2.5 py-1 text-xs font-semibold', theme.chip]}>
        <HeroIcon name={category.icon} class="h-3.5 w-3.5" />
        {category.title}
      </span>
      <span class="text-xl font-bold leading-snug transition group-hover:text-primary-500 dark:group-hover:text-primary-300">{post.data.title}</span>
      <span class="mt-3 line-clamp-3 grow leading-7 text-grey-500 dark:text-grey-300">{post.data.description}</span>
      <span class="mt-6 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-grey-500 dark:text-grey-300">
        <span class="inline-flex items-center gap-1.5">
          <HeroIcon name="CalendarDaysIcon" class="h-4 w-4" />
          <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate, lang)}</time>
        </span>
        <span class="inline-flex items-center gap-1.5">
          <HeroIcon name="ClockIcon" class="h-4 w-4" />
          {getReadingTime(post, lang)}
        </span>
      </span>
    </span>
  </a>
</article>

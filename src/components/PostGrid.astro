---
import { articlesUrl, getTranslations, type Lang } from '@i18n/index';
import type { Post } from '@utils/posts';
import HeroIcon from './HeroIcon.astro';
import PostCard from './PostCard.astro';

interface Props {
  posts: Post[];
  lang: Lang;
}

const { posts, lang } = Astro.props;
const t = getTranslations(lang);
---

<section class="page-shell py-12">
  <div class="mb-8 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <h2 class="text-2xl font-bold text-grey-800 dark:text-grey-50">{t.home.latestTitle}</h2>
      <p class="mt-2 max-w-2xl text-grey-500 dark:text-grey-300">{t.home.latestDescription}</p>
    </div>
  </div>
  {
    posts.length > 0 ? (
      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {posts.map((post) => <PostCard post={post} lang={lang} />)}
      </div>
    ) : (
      <p class="text-grey-500 dark:text-grey-300">{t.posts.empty}</p>
    )
  }
  <div class="mt-10 text-center">
    <a href={articlesUrl(lang)} class="inline-flex items-center gap-2 rounded-lg border border-grey-150 bg-grey-25 px-5 py-3 font-semibold text-grey-700 transition hover:-translate-y-0.5 hover:border-grey-300 hover:bg-grey-50 dark:border-grey-600 dark:bg-grey-900 dark:text-grey-100 dark:hover:border-grey-500 dark:hover:bg-grey-800">
      {t.home.viewAllArticles}
      <HeroIcon name="ArrowRightIcon" class="h-4 w-4" />
    </a>
  </div>
</section>

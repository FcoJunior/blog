---
import { articlesUrl, getTranslations, type Lang } from '@i18n/index';
import type { Post } from '@utils/posts';
import { formatDate, getCategoryUrl, getPostCover, getPostUrl, getReadingTime } from '@utils/posts';
import HeroIcon from './HeroIcon.astro';

interface Props {
  posts: Post[];
  lang: Lang;
}

const { posts, lang } = Astro.props;
const t = getTranslations(lang);
---

<section class="page-shell py-12">
  <div class="mb-8 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <h2 class="text-2xl font-bold text-grey-800 dark:text-grey-50">{t.home.latestTitle}</h2>
      <p class="mt-2 max-w-2xl text-grey-500 dark:text-grey-300">{t.home.latestDescription}</p>
    </div>
  </div>
  {
    posts.length > 0 ? (
      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {posts.map((post) => (
          <article class="flex min-h-full flex-col overflow-hidden rounded-2xl border border-grey-150 bg-grey-25 shadow-sm transition hover:-translate-y-1 hover:border-grey-300 hover:shadow-md dark:border-grey-600 dark:bg-grey-900 dark:hover:border-grey-500">
            <a href={getPostUrl(post)} class="block bg-grey-100 dark:bg-grey-800">
              <img
                src={getPostCover(post)}
                alt={`${t.posts.coverAlt} ${post.data.title}`}
                class="aspect-[16/9] w-full object-cover"
                loading="lazy"
              />
            </a>
            <div class="flex grow flex-col p-5">
              <div class="mb-3 flex flex-wrap gap-2">
                <a href={getCategoryUrl(lang, post.data.category)} class="rounded-full bg-primary-50 px-2.5 py-1 text-xs font-semibold text-primary-700 hover:bg-primary-100 dark:bg-primary-950 dark:text-primary-300 dark:hover:bg-primary-900">
                  {post.data.category}
                </a>
              </div>
              <a href={getPostUrl(post)} class="text-xl font-bold leading-snug text-grey-800 hover:text-primary-500 dark:text-grey-50">
                {post.data.title}
              </a>
              <p class="mt-3 grow leading-7 text-grey-500 dark:text-grey-300">{post.data.description}</p>
              <div class="mt-6 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-grey-500 dark:text-grey-300">
                <span class="inline-flex items-center gap-1.5">
                  <HeroIcon name="CalendarDaysIcon" class="h-4 w-4" />
                  <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate, lang)}</time>
                </span>
                <span class="inline-flex items-center gap-1.5">
                  <HeroIcon name="ClockIcon" class="h-4 w-4" />
                  {getReadingTime(post, lang)}
                </span>
              </div>
            </div>
          </article>
        ))}
      </div>
    ) : (
      <p class="text-grey-500 dark:text-grey-300">{t.posts.empty}</p>
    )
  }
  <div class="mt-10 text-center">
    <a href={articlesUrl(lang)} class="inline-flex items-center gap-2 rounded-lg border border-grey-150 bg-grey-25 px-5 py-3 font-semibold text-grey-700 transition hover:-translate-y-0.5 hover:border-grey-300 hover:bg-grey-50 dark:border-grey-600 dark:bg-grey-900 dark:text-grey-100 dark:hover:border-grey-500 dark:hover:bg-grey-800">
      {t.home.viewAllArticles}
      <HeroIcon name="ArrowRightIcon" class="h-4 w-4" />
    </a>
  </div>
</section>

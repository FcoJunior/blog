---
import BaseLayout from './BaseLayout.astro';
import Sidebar from '@components/Sidebar.astro';
import type { Post } from '@utils/posts';
import { formatDate, getCategoryUrl, getPostAlternates, getPostCover, getPostUrl } from '@utils/posts';
import { getSeoAlternates } from '@utils/seo';
import { homeUrl, type Lang } from '@i18n/index';
import { AUTHOR_NAME, getAuthorAvatarUrl } from '@utils/author';

interface Props {
  post: Post;
}

const { post } = Astro.props;
const lang = post.data.lang;
const tags = post.data.tags.join(', ');
const translatedPosts = await getPostAlternates(post);
const languageUrls: Partial<Record<Lang, string>> = {
  pt: translatedPosts.get('pt') ? getPostUrl(translatedPosts.get('pt')!) : homeUrl('pt'),
  en: translatedPosts.get('en') ? getPostUrl(translatedPosts.get('en')!) : homeUrl('en')
};
const seoUrls: Partial<Record<Lang, string>> = {};

for (const [itemLang, itemPost] of translatedPosts) {
  seoUrls[itemLang] = getPostUrl(itemPost);
}
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={getPostCover(post)}
  canonical={getPostUrl(post)}
  type="article"
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  lang={lang}
  languageUrls={languageUrls}
  alternates={getSeoAlternates(seoUrls)}
>
  <div class="page-shell py-8 flex flex-col lg:flex-row gap-4">
    <div class="w-full lg:w-3/4">
      <div class="prose max-w-none grow text-grey-500 dark:prose-invert dark:text-grey-100 lg:prose-xl">
        <article
          class="flex flex-col justify-center"
          data-pagefind-body
          data-pagefind-meta={`description:${post.data.description}`}
        >
          <h1 class="text-center text-grey-800 dark:text-grey-100" data-pagefind-meta="title">{post.data.title}</h1>
          <p class="sr-only" data-pagefind-meta="category">{post.data.category}</p>
          <p class="sr-only" data-pagefind-meta="tags">{tags}</p>
          <p class="sr-only" data-pagefind-meta="lang">{lang}</p>
          <div class="flex flex-col-reverse md:flex-col">
            <div class="not-prose flex flex-wrap items-center justify-start gap-3 py-3 font-mono text-lg text-grey-500 dark:text-grey-200 md:justify-center">
              <div class="flex gap-4 items-center">
                <img class="avatar avatar-48 photo h-12 w-12 rounded-full object-cover" src={getAuthorAvatarUrl(96)} alt={AUTHOR_NAME} />
                <span>Francisco Junior</span>
              </div>
              <span class="text-primary-400">-</span>
              <a href={getCategoryUrl(lang, post.data.category)} class="hover:text-primary-400">{post.data.category}</a>
              <span class="text-primary-400">-</span>
              <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate, lang)}</time>
            </div>
            <div>
              <div class="flex justify-center not-prose">
                <img class="rounded-2xl w-full max-h-[480px] object-cover" src={getPostCover(post)} alt={post.data.title} />
              </div>
              <div>
                <slot />
              </div>
              {
                post.data.tags.length > 0 && (
                  <div class="not-prose mt-10 flex flex-wrap gap-3 font-mono text-sm font-bold">
                    {post.data.tags.map((tag) => (
                      <span class="text-primary-500 dark:text-primary-400">#{tag}</span>
                    ))}
                  </div>
                )
              }
            </div>
          </div>
        </article>
      </div>
    </div>
    <aside class="lg:w-1/4 not-prose">
      <Sidebar title={post.data.title} url={new URL(getPostUrl(post), Astro.site ?? Astro.url).toString()} lang={lang} />
    </aside>
  </div>
</BaseLayout>

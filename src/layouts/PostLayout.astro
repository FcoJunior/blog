---
import BaseLayout from './BaseLayout.astro';
import ArticleHeader from '@components/ArticleHeader.astro';
import ArticleSidebar from '@components/ArticleSidebar.astro';
import AuthorSection from '@components/AuthorSection.astro';
import RelatedPosts from '@components/RelatedPosts.astro';
import type { Post } from '@utils/posts';
import { getPostAlternates, getPostCover, getPostUrl, getPublishedPostsByLang } from '@utils/posts';
import { getSeoAlternates } from '@utils/seo';
import { homeUrl, type Lang } from '@i18n/index';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  post: Post;
  headings?: Heading[];
}

const { post, headings = [] } = Astro.props;
const lang = post.data.lang;
const tags = post.data.tags.join(', ');
const posts = await getPublishedPostsByLang(lang);
const translatedPosts = await getPostAlternates(post);
const languageUrls: Partial<Record<Lang, string>> = {
  pt: translatedPosts.get('pt') ? getPostUrl(translatedPosts.get('pt')!) : homeUrl('pt'),
  en: translatedPosts.get('en') ? getPostUrl(translatedPosts.get('en')!) : homeUrl('en')
};
const seoUrls: Partial<Record<Lang, string>> = {};

for (const [itemLang, itemPost] of translatedPosts) {
  seoUrls[itemLang] = getPostUrl(itemPost);
}
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={getPostCover(post)}
  canonical={getPostUrl(post)}
  type="article"
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  lang={lang}
  languageUrls={languageUrls}
  alternates={getSeoAlternates(seoUrls)}
>
  <ArticleHeader post={post} lang={lang} />

  <div class="page-shell pb-6">
    <div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-[minmax(0,1fr)_18rem] lg:items-start">
      <article
        class="min-w-0"
        data-pagefind-body
        data-pagefind-meta={`description:${post.data.description}`}
      >
        <p class="sr-only" data-pagefind-meta="category">{post.data.category}</p>
        <p class="sr-only" data-pagefind-meta="tags">{tags}</p>
        <p class="sr-only" data-pagefind-meta="lang">{lang}</p>
        <div class="prose prose-lg max-w-none text-grey-500 dark:prose-invert dark:text-grey-100 lg:prose-xl prose-headings:scroll-mt-28 prose-headings:font-bold prose-p:leading-8 prose-a:font-medium">
          <slot />
        </div>
      </article>

      <aside class="not-prose order-last lg:sticky lg:top-24 lg:order-none lg:max-h-[calc(100vh-7rem)] lg:self-start lg:overflow-y-auto">
        <ArticleSidebar title={post.data.title} url={new URL(getPostUrl(post), Astro.site ?? Astro.url).toString()} lang={lang} headings={headings} />
      </aside>
    </div>
  </div>

  <AuthorSection lang={lang} constrained />
  <RelatedPosts posts={posts} currentPost={post} lang={lang} />
</BaseLayout>

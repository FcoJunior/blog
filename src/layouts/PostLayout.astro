---
import BaseLayout from './BaseLayout.astro';
import Sidebar from '@components/Sidebar.astro';
import type { Post } from '@utils/posts';
import { formatDate, getPostCover, getPostSlug, slugify } from '@utils/posts';

interface Props {
  post: Post;
}

const { post } = Astro.props;
const slug = getPostSlug(post);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={getPostCover(post)}
  canonical={`/artigos/${slug}`}
  type="article"
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
>
  <div class="page-shell py-8 flex flex-col lg:flex-row gap-4">
    <div class="w-full lg:w-3/4">
      <div class="prose lg:prose-xl max-w-none text-grey-100 grow">
        <article class="flex flex-col justify-center">
          <h1 class="text-grey-100 text-center">{post.data.title}</h1>
          <div class="flex flex-col-reverse md:flex-col">
            <div class="flex justify-start md:justify-center flex-wrap gap-3 py-3 not-prose font-mono text-lg items-center text-grey-200">
              <div class="flex gap-4 items-center">
                <img class="avatar avatar-48 photo rounded-full h-12 w-12" src="/images/logo-menu.png" alt="Dev Junior" />
                <span>Dev Junior</span>
              </div>
              <span class="text-primary-400">-</span>
              <span>{post.data.tags.join(', ')}</span>
              <span class="text-primary-400">-</span>
              <a href={`/categorias/${slugify(post.data.category)}`} class="hover:text-primary-400">{post.data.category}</a>
              <span class="text-primary-400">-</span>
              <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
            </div>
            <div>
              <div class="flex justify-center not-prose">
                <img class="rounded-2xl w-full max-h-[480px] object-cover" src={getPostCover(post)} alt={`Capa do artigo ${post.data.title}`} />
              </div>
              <div>
                <slot />
              </div>
            </div>
          </div>
        </article>
      </div>
    </div>
    <aside class="lg:w-1/4 not-prose">
      <Sidebar title={post.data.title} url={new URL(`/artigos/${slug}`, Astro.site ?? Astro.url).toString()} />
    </aside>
  </div>
</BaseLayout>

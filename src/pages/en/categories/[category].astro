---
import CategoryHero from '@components/CategoryHero.astro';
import CategoryNav from '@components/CategoryNav.astro';
import CategoryPostGrid from '@components/CategoryPostGrid.astro';
import { categories, getCategoryByName, getCategoryBySlug, getCategoryMetadata, listCategories } from '@config/categories';
import BaseLayout from '@layouts/BaseLayout.astro';
import { categoriesUrl } from '@i18n/index';
import { getPublishedPostsByLang, slugify, type Post } from '@utils/posts';
import { getSeoAlternates } from '@utils/seo';

export async function getStaticPaths() {
  const posts = await getPublishedPostsByLang('en');
  const categoryMap = new Map<string, { category: string; posts: Post[] }>();

  for (const category of listCategories('en')) {
    categoryMap.set(category.slug, { category: category.title, posts: [] });
  }

  for (const post of posts) {
    const category = getCategoryMetadata('en', post.data.category);
    if (!categoryMap.has(category.slug)) categoryMap.set(category.slug, { category: category.title, posts: [] });
    categoryMap.get(category.slug)?.posts.push(post);
  }

  return Array.from(categoryMap.entries()).map(([slug, data]) => ({
    params: { category: slug },
    props: data
  }));
}

const { category, posts } = Astro.props;
const lang = 'en';
const slug = slugify(category);
const categoryConfig = getCategoryBySlug(lang, slug) ?? getCategoryByName(lang, category);
const categoryMetadata = getCategoryMetadata(lang, category);
const allCategories = listCategories(lang);
const ptSlug = categoryConfig ? categories[categoryConfig.id].slug.pt : slug;
const enSlug = categoryConfig ? categories[categoryConfig.id].slug.en : slug;
const languageUrls = {
  pt: categoriesUrl('pt', ptSlug),
  en: categoriesUrl('en', enSlug)
};
---

<BaseLayout
  title={categoryMetadata.title}
  description={categoryMetadata.description}
  canonical={languageUrls.en}
  lang={lang}
  languageUrls={languageUrls}
  alternates={getSeoAlternates(languageUrls)}
>
  <section class="page-shell">
    <CategoryHero category={categoryMetadata} count={posts.length} lang={lang} />
  </section>
  <CategoryNav categories={allCategories} currentSlug={categoryMetadata.slug} lang={lang} />
  <CategoryPostGrid posts={posts} lang={lang} />
</BaseLayout>

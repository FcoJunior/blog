---
import PostList from '@components/PostList.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import { categoriesUrl, getTranslations } from '@i18n/index';
import { getPublishedPostsByLang, slugify } from '@utils/posts';
import { getSeoAlternates } from '@utils/seo';

export async function getStaticPaths() {
  const posts = await getPublishedPostsByLang('en');
  const categories = new Map();
  const t = getTranslations('en');

  for (const category of t.home.categories) {
    const slug = slugify(category.name);
    if (!categories.has(slug)) categories.set(slug, { category: category.name, posts: [] });
  }

  for (const post of posts) {
    const slug = slugify(post.data.category);
    if (!categories.has(slug)) categories.set(slug, { category: post.data.category, posts: [] });
    categories.get(slug).posts.push(post);
  }

  return Array.from(categories.entries()).map(([slug, data]) => ({
    params: { category: slug },
    props: data
  }));
}

const { category, posts } = Astro.props;
const lang = 'en';
const t = getTranslations(lang);
const slug = slugify(category);
const languageUrls = {
  pt: categoriesUrl('pt', slug),
  en: categoriesUrl('en', slug)
};
---

<BaseLayout
  title={category}
  description={`${t.posts.categoryDescription} ${category} on Dev Junior.`}
  canonical={languageUrls.en}
  lang={lang}
  languageUrls={languageUrls}
  alternates={getSeoAlternates(languageUrls)}
>
  <section class="page-shell py-8">
    <div class="flex gap-4 items-center pb-8">
      <hr class="w-full flex-1 border-grey-150 dark:border-grey-600" />
      <h1 class="text-xl font-bold">{category}</h1>
      <hr class="w-full flex-1 border-grey-150 dark:border-grey-600" />
    </div>
    <PostList posts={posts} lang={lang} />
  </section>
</BaseLayout>

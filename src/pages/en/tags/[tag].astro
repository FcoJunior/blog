---
import PostList from '@components/PostList.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import { getTranslations, tagsUrl } from '@i18n/index';
import { getPublishedPostsByLang, slugify } from '@utils/posts';
import { getSeoAlternates } from '@utils/seo';

export async function getStaticPaths() {
  const posts = await getPublishedPostsByLang('en');
  const tags = new Map();

  for (const post of posts) {
    for (const tag of post.data.tags) {
      const slug = slugify(tag);
      if (!tags.has(slug)) tags.set(slug, { tag, posts: [] });
      tags.get(slug).posts.push(post);
    }
  }

  return Array.from(tags.entries()).map(([slug, data]) => ({
    params: { tag: slug },
    props: data
  }));
}

const { tag, posts } = Astro.props;
const lang = 'en';
const t = getTranslations(lang);
const slug = slugify(tag);
const languageUrls = {
  pt: tagsUrl('pt', slug),
  en: tagsUrl('en', slug)
};
---

<BaseLayout
  title={`# ${tag}`}
  description={`${t.posts.tagDescription} ${tag} on Dev Junior.`}
  canonical={languageUrls.en}
  lang={lang}
  languageUrls={languageUrls}
  alternates={getSeoAlternates(languageUrls)}
>
  <section class="page-shell py-8">
    <div class="flex gap-4 items-center pb-8">
      <hr class="w-full flex-1 border-grey-150 dark:border-grey-600" />
      <h1 class="text-xl font-bold"># {tag}</h1>
      <hr class="w-full flex-1 border-grey-150 dark:border-grey-600" />
    </div>
    <PostList posts={posts} lang={lang} />
  </section>
</BaseLayout>

---
import CategoryNav from '@components/CategoryNav.astro';
import HeroIcon from '@components/HeroIcon.astro';
import { listCategories } from '@config/categories';
import BaseLayout from '@layouts/BaseLayout.astro';
import { articlesUrl, homeUrl } from '@i18n/index';

const lang = 'pt';
const categories = listCategories(lang);
---

<BaseLayout
  title="Página não encontrada"
  description="A página que você procura não existe, foi movida ou o endereço informado está incorreto."
  lang={lang}
>
  <section class="page-shell flex min-h-[calc(100svh-10rem)] flex-col items-center justify-center py-16 text-center sm:py-20 lg:py-24">
    <div class="flex max-w-3xl flex-col items-center">
      
      <p class="mt-8 font-mono text-7xl font-bold leading-none text-grey-800 dark:text-grey-50 sm:text-8xl lg:text-9xl">
        404
      </p>

      <h1 class="mt-5 text-2xl font-bold text-grey-800 dark:text-grey-50 sm:text-3xl">
        Resource not found
      </h1>

      <p class="mt-4 max-w-xl text-base leading-7 text-grey-500 dark:text-grey-300 sm:text-lg sm:leading-8">
        A página que você procura não existe, foi movida ou o endereço informado está incorreto.
      </p>

      <div class="mt-8 flex w-full flex-col justify-center gap-3 sm:w-auto sm:flex-row">
        <a
          href={homeUrl(lang)}
          class="inline-flex items-center justify-center gap-2 rounded-lg bg-grey-800 px-5 py-3 font-semibold text-grey-50 transition hover:-translate-y-0.5 hover:bg-grey-700 dark:bg-grey-50 dark:text-grey-900 dark:hover:bg-grey-100"
        >
          Voltar para Home
        </a>
        <a
          href={articlesUrl(lang)}
          class="inline-flex items-center justify-center gap-2 rounded-lg border border-grey-150 bg-grey-25 px-5 py-3 font-semibold text-grey-700 transition hover:-translate-y-0.5 hover:border-grey-300 hover:bg-grey-50 dark:border-grey-600 dark:bg-grey-900 dark:text-grey-100 dark:hover:border-grey-500 dark:hover:bg-grey-800"
        >
          Explorar artigos
          <HeroIcon name="ArrowRightIcon" class="h-4 w-4" />
        </a>
      </div>
    </div>

    <div class="mt-12 w-full max-w-5xl">
      <p class="mb-5 text-sm font-semibold text-grey-500 dark:text-grey-300">
        Ou explore um dos assuntos abaixo
      </p>
      <CategoryNav categories={categories} lang={lang} showAllLink={false} />
    </div>
  </section>
</BaseLayout>

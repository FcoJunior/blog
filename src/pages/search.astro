---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Busca" description="Busque artigos do Dev Junior por titulo, descricao, tag ou categoria.">
  <section class="page-shell py-8">
    <header class="mb-6">
      <h1 class="text-2xl font-bold text-grey-100">Busca</h1>
      <p class="text-grey-300 mt-2">Encontre artigos por título, descrição, tag ou categoria.</p>
    </header>

    <div class="flex flex-col md:flex-row gap-4 mb-8">
      <input
        id="search-input"
        type="search"
        autocomplete="off"
        placeholder="Buscar"
        class="bg-grey-600 rounded-2xl py-2 px-4 focus:outline-none placeholder:text-grey-300 w-full md:w-1/2"
      />
      <button id="search-button" class="bg-primary-600 px-4 py-2 rounded-2xl hover:bg-primary-700">
        Buscar
      </button>
    </div>

    <p id="search-status" class="text-grey-300 mb-4"></p>
    <div id="search-results" class="flex flex-col flex-wrap md:flex-row lg:justify-start items-start"></div>
  </section>

  <template id="post-card-template">
    <article class="w-full md:w-1/2 lg:w-1/3 xl:w-1/4">
      <div class="border border-grey-600 rounded-2xl m-3 h-[calc(100%-1.5rem)] flex flex-col overflow-hidden">
        <a data-cover-link class="block bg-grey-700">
          <img data-cover class="rounded-t-2xl w-full aspect-[1882/930] object-cover" loading="lazy" />
        </a>
        <div class="p-4 text-grey-50 flex flex-col gap-4 grow">
          <div class="flex flex-col gap-2">
            <div data-tags class="text-primary-400 font-mono flex flex-wrap gap-x-2 gap-y-1"></div>
            <a data-title class="font-bold text-lg hover:text-primary-500"></a>
          </div>
          <p data-description class="text-grey-300 text-justify grow"></p>
          <span data-date class="text-grey-300 font-mono text-sm"></span>
        </div>
      </div>
    </article>
  </template>

  <script>
    // @ts-nocheck
    const input = document.getElementById('search-input');
    const button = document.getElementById('search-button');
    const results = document.getElementById('search-results');
    const status = document.getElementById('search-status');
    const template = document.getElementById('post-card-template');
    const params = new URLSearchParams(window.location.search);

    const normalize = (value) =>
      value
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .toLowerCase();

    const renderPost = (post) => {
      const fragment = template.content.cloneNode(true);
      const coverLink = fragment.querySelector('[data-cover-link]');
      const cover = fragment.querySelector('[data-cover]');
      const title = fragment.querySelector('[data-title]');
      const description = fragment.querySelector('[data-description]');
      const tags = fragment.querySelector('[data-tags]');
      const date = fragment.querySelector('[data-date]');

      coverLink.href = post.url;
      cover.src = post.cover;
      cover.alt = `Capa do artigo ${post.title}`;
      title.href = post.url;
      title.textContent = post.title;
      description.textContent = post.description;
      date.textContent = post.pubDate;
      tags.innerHTML = post.tags.map((tag) => `<span># ${tag}</span>`).join('');

      return fragment;
    };

    const runSearch = async () => {
      const query = input.value.trim();
      const response = await fetch('/search.json');
      const posts = await response.json();

      const filtered = query
        ? posts.filter((post) => {
            const haystack = normalize([post.title, post.description, post.category, ...post.tags].join(' '));
            return haystack.includes(normalize(query));
          })
        : posts;

      results.replaceChildren(...filtered.map(renderPost));
      status.textContent = filtered.length
        ? `${filtered.length} resultado(s) encontrado(s).`
        : 'Nenhum resultado encontrado para sua busca.';

      const nextUrl = new URL(window.location.href);
      if (query) nextUrl.searchParams.set('q', query);
      else nextUrl.searchParams.delete('q');
      window.history.replaceState({}, '', nextUrl);
    };

    input.value = params.get('q') ?? '';
    button.addEventListener('click', runSearch);
    input.addEventListener('keydown', (event) => {
      if (event.key === 'Enter') runSearch();
    });
    runSearch();
  </script>
</BaseLayout>

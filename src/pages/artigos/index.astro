---
import CategoryHero from '@components/CategoryHero.astro';
import CategoryNav from '@components/CategoryNav.astro';
import CategoryPostGrid from '@components/CategoryPostGrid.astro';
import { listCategories, type CategoryMetadata } from '@config/categories';
import BaseLayout from '@layouts/BaseLayout.astro';
import { articlesUrl, getTranslations } from '@i18n/index';
import { getPublishedPostsByLang } from '@utils/posts';
import { getSeoAlternates } from '@utils/seo';

const lang = 'pt';
const t = getTranslations(lang);
const posts = await getPublishedPostsByLang(lang);
const categories = listCategories(lang);
const allArticlesCategory: CategoryMetadata = {
  id: 'fallback',
  slug: '',
  title: 'Todos os artigos',
  description: 'Publicações recentes sobre desenvolvimento, arquitetura, .NET, front-end, DevOps e carreira em tecnologia.',
  icon: 'BookOpenIcon',
  color: 'blue',
  href: articlesUrl(lang)
};
const languageUrls = {
  pt: articlesUrl('pt'),
  en: articlesUrl('en')
};
---

<BaseLayout
  title={t.posts.articles}
  description={t.site.description}
  canonical={languageUrls.pt}
  lang={lang}
  languageUrls={languageUrls}
  alternates={getSeoAlternates(languageUrls)}
>
  <section class="page-shell">
    <CategoryHero category={allArticlesCategory} count={posts.length} lang={lang} />
  </section>
  <CategoryNav categories={categories} lang={lang} />
  <CategoryPostGrid posts={posts} lang={lang} />
</BaseLayout>

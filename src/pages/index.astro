---
import AuthorSection from '@components/AuthorSection.astro';
import CategoryCard from '@components/CategoryCard.astro';
import FeaturedPost from '@components/FeaturedPost.astro';
import HeroSection from '@components/HeroSection.astro';
import PostGrid from '@components/PostGrid.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import { getTranslations, homeUrl } from '@i18n/index';
import { getFeaturedPost, getPublishedPostsByLang } from '@utils/posts';
import { getSeoAlternates } from '@utils/seo';

const lang = 'pt';
const t = getTranslations(lang);
const posts = await getPublishedPostsByLang(lang);
const featuredPost = getFeaturedPost(posts);
const latestPosts = posts.slice(0, 6);
const languageUrls = {
  pt: homeUrl('pt'),
  en: homeUrl('en')
};
---

<BaseLayout
  title={t.site.title}
  description={t.site.description}
  canonical={homeUrl(lang)}
  lang={lang}
  languageUrls={languageUrls}
  alternates={getSeoAlternates(languageUrls)}
>
  <HeroSection lang={lang} />

  <section id={t.home.categoriesId} class="page-shell scroll-mt-28 py-12">
    <div class="mb-8 max-w-2xl">
      <h2 class="text-2xl font-bold text-grey-800 dark:text-grey-50">{t.home.categoriesTitle}</h2>
      <p class="mt-2 text-grey-500 dark:text-grey-300">{t.home.categoriesDescription}</p>
    </div>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      {t.home.categories.map((category) => <CategoryCard {...category} />)}
    </div>
  </section>

  <FeaturedPost post={featuredPost} lang={lang} />
  <PostGrid posts={latestPosts} lang={lang} />
  <AuthorSection lang={lang} />
</BaseLayout>
